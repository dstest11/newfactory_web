{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} — New Factory{% endblock %}

{% block meta %}
    <meta name="description" content="{{ product.name }} — {{ product.hashrate }} ASIC miner pro Bitcoin. Transparentní ALL-IN cena. {{ product.short_description }}">
{% endblock %}

{% block body %}
{% set base = product.machine_price_czk + product.accessories_czk %}
{% set required = 0 %}
{% set optional_total = 0 %}
{% for line in product.service_lines %}
    {% if line.is_optional %}
        {% set optional_total = optional_total + line.price_czk %}
    {% else %}
        {% set required = required + line.price_czk %}
    {% endif %}
{% endfor %}
{% set allin = base + required %}
{% set efficiency = (product.power_w / (product.hashrate|split(' ')[0]))|round(1) %}
{% set product_index = { 'antminer-s21-pro': 1, 'antminer-s21-hyd': 2, 'whatsminer-m60s': 3 }[product.slug]|default(1) %}

<div class="nf-shell">
<header class="nf-header">
    <a href="{{ path('home') }}" class="nf-header__brand">
        <span class="nf-display">NEW</span><span class="nf-display nf-display--accent">FACTORY</span>
    </a>
    <nav class="nf-header__nav">
        <a href="{{ path('home') }}"><span class="nf-mono">[01]</span> Úvod</a>
        <a href="{{ path('product_list') }}"><span class="nf-mono">[02]</span> Stroje</a>
        <a href="{{ path('contact') }}"><span class="nf-mono">[03]</span> Kontakt</a>
    </nav>
</header>

<main id="main" class="nf-page nf-page--detail">
    <nav class="nf-breadcrumb"><a href="{{ path('product_list') }}">← <span class="nf-mono">[02]</span> Zpět na katalog strojů</a></nav>

    <!-- HERO: dossier-style with index + title spanning + portrait + metrics rail -->
    <section class="nf-hero">
        <div class="nf-hero__caption">
            <p class="nf-eyebrow">[STROJ / {{ '%02d'|format(product_index) }} / 03]</p>
            <p class="nf-hero__kicker">
                <span class="nf-mono">{{ product.manufacturer|upper }}</span>
                &nbsp;·&nbsp;
                <span class="nf-mono">{{ product.algorithm }}</span>
                &nbsp;·&nbsp;
                <span class="nf-mono">{{ product.currency_type|upper }}</span>
            </p>
        </div>
        <h1 class="nf-display nf-hero__title">{{ product.name }}</h1>

        <div class="nf-hero__portrait">
            <img src="/victor/resources/images/portfolio/portfolio{{ product_index }}.jpg" alt="{{ product.name }}" />
            <span class="nf-hero__badge nf-hero__badge--{{ product.delivery|lower|replace({' ': '-'}) }}">{{ product.delivery }}</span>
            <span class="nf-hero__portrait-meta nf-mono">[OBR&nbsp;·&nbsp;{{ '%02d'|format(product_index) }}/03]</span>
        </div>

        <p class="nf-hero__pitch">{{ product.short_description }}</p>

        <div class="nf-metrics">
            <article class="nf-metric nf-metric--xl">
                <span class="nf-metric__label">HASHRATE</span>
                <strong class="nf-display nf-metric__value">{{ product.hashrate|split(' ')[0] }}</strong>
                <span class="nf-metric__unit">{{ product.hashrate|split(' ')[1]|default('TH/s') }}</span>
            </article>
            <article class="nf-metric">
                <span class="nf-metric__label">Datum zapojení</span>
                <strong class="nf-display nf-metric__value">48</strong>
                <span class="nf-metric__unit">hodin</span>
            </article>
            <article class="nf-metric">
                <span class="nf-metric__label">Roční výnos <sup title="Odhad podle aktuální obtížnosti sítě a kurzu BTC; výsledná hodnota není garantovaná.">ⓘ</sup></span>
                <strong class="nf-display nf-metric__value">{{ product.annual_btc|replace({'≈ ': ''})|split(' ')[0] }}</strong>
                <span class="nf-metric__unit">BTC / rok</span>
            </article>
            <article class="nf-metric">
                <span class="nf-metric__label">Účinnost</span>
                <strong class="nf-display nf-metric__value">{{ efficiency }}</strong>
                <span class="nf-metric__unit">J / TH</span>
            </article>
            <article class="nf-metric">
                <span class="nf-metric__label">Příkon</span>
                <strong class="nf-display nf-metric__value">{{ (product.power_w / 1000)|number_format(2, ',', ' ') }}</strong>
                <span class="nf-metric__unit">kW</span>
            </article>
        </div>

        <a class="nf-btn nf-btn--primary nf-btn--xl nf-hero__cta" href="{{ path('contact', { product: product.slug }) }}">
            Mám zájem — pošlete cenovou nabídku →
        </a>
    </section>

    <!-- PRICE LEDGER: asymmetric, left column copy + right column running tape -->
    <section class="nf-ledger">
        <div class="nf-ledger__intro">
            <p class="nf-eyebrow">[CENOVÁ&nbsp;KALKULACE]</p>
            <h2 class="nf-display">ALL-IN<br><span class="nf-display--accent">{{ allin|number_format(0, ',', ' ') }}&nbsp;Kč</span></h2>
            <p class="nf-ledger__lead">Plně transparentní rozpočet. <strong>Žádné skryté poplatky.</strong> ALL-IN obsahuje pouze povinné položky; volitelné si určujete při poptávce. Cena za elektřinu je fakturována odděleně podle reálné spotřeby.</p>
            <dl class="nf-ledger__totals">
                <div><dt>Povinné položky</dt><dd class="nf-mono nf-ledger__totals-required">{{ allin|number_format(0, ',', ' ') }} Kč</dd></div>
                <div><dt>S volitelnými službami</dt><dd class="nf-mono">{{ (allin + optional_total)|number_format(0, ',', ' ') }} Kč</dd></div>
                <div><dt>Elektřina (provoz / rok)</dt><dd class="nf-mono">{{ product.electricity_yearly_czk|number_format(0, ',', ' ') }} Kč</dd></div>
            </dl>
        </div>

        <div class="nf-ledger__sheet">
            <p class="nf-ledger__sheet-head">
                <span class="nf-mono">POL.</span>
                <span class="nf-mono">POPIS</span>
                <span class="nf-mono">TYP</span>
                <span class="nf-mono nf-ledger__sheet-head-price">CENA</span>
            </p>
            <ol class="nf-ledger__lines">
                <li class="is-required">
                    <span class="nf-mono nf-ledger__lines-num">001</span>
                    <span class="nf-ledger__lines-name">Cena stroje</span>
                    <span class="nf-mono nf-ledger__lines-type">stroj</span>
                    <span class="nf-mono nf-ledger__lines-price">{{ product.machine_price_czk|number_format(0, ',', ' ') }} Kč</span>
                </li>
                <li class="is-required">
                    <span class="nf-mono nf-ledger__lines-num">002</span>
                    <span class="nf-ledger__lines-name">Příslušenství (kabely, vzduchové filtry)</span>
                    <span class="nf-mono nf-ledger__lines-type">stroj</span>
                    <span class="nf-mono nf-ledger__lines-price">{{ product.accessories_czk|number_format(0, ',', ' ') }} Kč</span>
                </li>
                {% for line in product.service_lines %}
                    <li class="{{ line.is_optional ? 'is-optional' : 'is-required' }}">
                        <span class="nf-mono nf-ledger__lines-num">{{ '%03d'|format(loop.index + 2) }}</span>
                        <span class="nf-ledger__lines-name">{{ line.is_optional ? '◇' : '◆' }} {{ line.name }}</span>
                        <span class="nf-mono nf-ledger__lines-type">{{ line.is_optional ? 'volitelné' : 'povinné' }}</span>
                        <span class="nf-mono nf-ledger__lines-price">{{ line.price_czk|number_format(0, ',', ' ') }} Kč</span>
                    </li>
                {% endfor %}
            </ol>
            <p class="nf-ledger__sheet-totals">
                <span class="nf-mono nf-ledger__sheet-totals-row">
                    <span>= ALL-IN (povinné)</span>
                    <strong class="nf-ledger__sheet-totals-allin">{{ allin|number_format(0, ',', ' ') }} Kč</strong>
                </span>
                <span class="nf-mono nf-ledger__sheet-totals-row">
                    <span>+ Volitelné služby</span>
                    <span>{{ optional_total|number_format(0, ',', ' ') }} Kč</span>
                </span>
                <span class="nf-mono nf-ledger__sheet-totals-row nf-ledger__sheet-totals-energy">
                    <span>+ Elektřina @ 5 Kč/kWh</span>
                    <span>{{ product.electricity_yearly_czk|number_format(0, ',', ' ') }} Kč / rok</span>
                </span>
            </p>
        </div>
    </section>

    <!-- SPECS: off-grid mosaic blocks -->
    <section class="nf-specs">
        <header class="nf-specs__head">
            <p class="nf-eyebrow">[TECHNICKÉ&nbsp;PARAMETRY]</p>
            <h2 class="nf-display">Pod kapotou.</h2>
        </header>
        <dl class="nf-specs__grid">
            <div class="nf-specs__cell"><dt>Výrobce</dt><dd>{{ product.manufacturer }}</dd></div>
            <div class="nf-specs__cell"><dt>Představení</dt><dd>{{ product.release_date }}</dd></div>
            <div class="nf-specs__cell nf-specs__cell--big"><dt>Hashrate</dt><dd class="nf-mono">{{ product.hashrate }}</dd></div>
            <div class="nf-specs__cell"><dt>Algoritmus</dt><dd class="nf-mono">{{ product.algorithm }}</dd></div>
            <div class="nf-specs__cell"><dt>Příkon</dt><dd class="nf-mono">{{ product.power_w|number_format(0, ',', ' ') }} W</dd></div>
            <div class="nf-specs__cell nf-specs__cell--big"><dt>Energetická efektivita</dt><dd class="nf-mono">{{ efficiency }} J / TH</dd></div>
            <div class="nf-specs__cell"><dt>Rozměry</dt><dd class="nf-mono">{{ product.dimensions }}</dd></div>
            <div class="nf-specs__cell"><dt>Váha</dt><dd class="nf-mono">{{ product.weight_kg }} kg</dd></div>
            <div class="nf-specs__cell"><dt>Provozní teplota</dt><dd class="nf-mono">0 – 40 °C</dd></div>
            <div class="nf-specs__cell"><dt>Rozhraní</dt><dd class="nf-mono">Ethernet (RJ45)</dd></div>
        </dl>
    </section>

    <!-- DESCRIPTION: editorial spread -->
    <section class="nf-essay">
        <p class="nf-eyebrow">[CO&nbsp;BYSTE&nbsp;MĚLI&nbsp;VĚDĚT]</p>
        <h2 class="nf-display">Stroj patří vám.<br><span class="nf-display--accent">Vytěžený BTC&nbsp;taky.</span></h2>
        <p class="nf-essay__lead">{{ product.short_description }}</p>
        <dl class="nf-essay__list">
            <div>
                <dt><span class="nf-mono">[01]</span> Životnost stroje</dt>
                <dd>3–5 let při doporučovaném provozu a údržbě podle výrobce. Pravidelný servis spolehlivě prodlužuje životnost o další 1–2 roky.</dd>
            </div>
            <div>
                <dt><span class="nf-mono">[02]</span> Vlastníte stroj</dt>
                <dd>Po odeslání ALL-IN platby je stroj váš. Nemáme nárok na podíl ze zisku ani provizi z vytěženého BTC. Cash flow do vaší kapsy, ne do naší.</dd>
            </div>
            <div>
                <dt><span class="nf-mono">[03]</span> Vyplácení</dt>
                <dd>BTC se těží na váš pool účet — výplaty řešíte přímo s pool providerem. Doporučujeme F2Pool, Antpool nebo Foundry USA.</dd>
            </div>
            <div>
                <dt><span class="nf-mono">[04]</span> Servis</dt>
                <dd>Po skončení záruky výrobce přebíráme bezplatný doživotní servis. Diagnostika i drobné opravy bez doplatků.</dd>
            </div>
            <div>
                <dt><span class="nf-mono">[05]</span> SLA uptime</dt>
                <dd>98 % garance v rámci jednoho fakturačního měsíce. Delší výpadek kompenzován výnosem podle aktuální obtížnosti sítě a kurzu BTC.</dd>
            </div>
        </dl>
    </section>

    <!-- FAQ -->
    <section class="nf-faq">
        <header class="nf-faq__head">
            <p class="nf-eyebrow">[FAQ&nbsp;/&nbsp;K&nbsp;TOMUTO&nbsp;STROJI]</p>
            <h2 class="nf-display">Než se zeptáte<br><span class="nf-display--accent">— a&nbsp;možná jsme&nbsp;odpověděli.</span></h2>
        </header>
        <div class="nf-faq__list">
            {% for faq in faqs|default([]) %}
                <details>
                    <summary><span class="nf-mono">[Q{{ loop.index }}]</span> {{ faq.question }}</summary>
                    <p>{{ faq.answer }}</p>
                </details>
            {% endfor %}
        </div>
    </section>

    <section class="nf-callout">
        <div class="nf-callout__copy">
            <p class="nf-eyebrow">[NEZÁVAZNÁ&nbsp;POPTÁVKA]</p>
            <h2 class="nf-display">Ozveme se <span class="nf-display--accent">do 24 hodin.</span></h2>
            <p>Pošleme kalkulaci se všemi volitelnými službami, ukážeme datum nasazení do datacentra a probereme tarif za elektřinu.</p>
        </div>
        <a class="nf-btn nf-btn--primary nf-btn--xl" href="{{ path('contact', { product: product.slug }) }}">Poslat poptávku →</a>
    </section>

    <p class="nf-disclaimer"><small>Odhadovaný hrubý příjem v BTC vychází z aktuální obtížnosti sítě a kurzu k dnešnímu datu. Skutečný výnos je závislý na vývoji sítě, kurzu BTC a uptime. Údaje nejsou garantovaným výnosem.</small></p>
</main>

<footer class="nf-footer">
    <p><span class="nf-mono">©&nbsp;{{ "now"|date("Y") }}</span> New Factory &nbsp;·&nbsp; <a href="mailto:mining@new-factory.cz">mining@new-factory.cz</a></p>
    <p class="nf-footer__meta nf-mono">[BTC&nbsp;ASIC&nbsp;DISTRIBUTOR&nbsp;·&nbsp;CZ]</p>
</footer>
</div>
{% endblock %}
