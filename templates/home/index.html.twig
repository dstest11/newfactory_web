{# Victor 3D template port — rebranded to New Factory mining hardware.
   Static assets live at /victor/* (copied verbatim from the Victor base);
   only HTML structure here is templated so editorial content (hero, about,
   services, contact info) can later be replaced with Strapi-fetched values. #}
{% extends 'home/_victor_base.html.twig' %}

{% block body %}
<!-- MAIN UI ELEMENTS -->
<main class="ui-wrapper page-not-loaded">
    <!-- LOADER -->
    <div class="loader flex flex--center">
        <span class="loader__text">NEW FACTORY</span>
    </div>

    <!-- MAIN MENU -->
    <div class="menu">
        <ul class="menu-list">
            <li class="menu-list__item" data-page="1">STROJE</li>
            <li class="menu-list__item" data-page="2">SLUŽBY</li>
            <li class="menu-list__item" data-page="3">PROČ NÁS</li>
            <li class="menu-list__item" data-page="4">TÝM</li>
            <li class="menu-list__item" data-page="5">KONTAKT</li>
        </ul>
    </div>

    <!-- OFFERS POPUP (full service list) -->
    <div class="popup" data-popup="offers">
        <div class="popup__inner">
            <h2 class="popup__title">CO NABÍZÍME</h2>
            <h2 class="popup__subtitle">Komplet řešení pro Bitcoin mining</h2>
            <div class="popup__content popup__offers">
                <div class="popup__offer">
                    <h3 class="popup__offer-title">Hardware</h3>
                    <ul>
                        <li>Antminer S21 Pro / Hydro</li>
                        <li>Whatsminer M60S</li>
                        <li>Bitmain & MicroBT distribuce</li>
                        <li>Pravé záruky výrobce</li>
                    </ul>
                </div>
                <div class="popup__offer">
                    <h3 class="popup__offer-title">Instalace</h3>
                    <ul>
                        <li>Provoz na klíč</li>
                        <li>Hosting v datacentru</li>
                        <li>Vodní chlazení (Hydro)</li>
                        <li>Konfigurace pool</li>
                    </ul>
                </div>
                <div class="popup__offer">
                    <h3 class="popup__offer-title">Provoz</h3>
                    <ul>
                        <li>24/7 monitoring</li>
                        <li>Reporting hashrate</li>
                        <li>Vzdálená správa</li>
                        <li>Email alerts</li>
                    </ul>
                </div>
                <div class="popup__offer">
                    <h3 class="popup__offer-title">Záruka</h3>
                    <ul>
                        <li>24 měs. standard</li>
                        <li>Rozšířená záruka 48 měs.</li>
                        <li>Servis ČR</li>
                        <li>Náhradní zápůjčka</li>
                    </ul>
                </div>
                <div class="popup__offer">
                    <h3 class="popup__offer-title">Poradenství</h3>
                    <ul>
                        <li>Výběr stroje</li>
                        <li>Kalkulace návratnosti</li>
                        <li>Daňové konsekvence</li>
                        <li>Tarify elektřiny</li>
                    </ul>
                </div>
                <div class="popup__offer">
                    <h3 class="popup__offer-title">Doprava</h3>
                    <ul>
                        <li>ČR + SK</li>
                        <li>EU partnerská síť</li>
                        <li>Pojištění zásilky</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- TEAM POPUP -->
    <div class="popup" data-popup="team">
        <div class="popup__inner">
            <h2 class="popup__title">LIDÉ ZA NEW FACTORY</h2>
            <h3 class="popup__subtitle">Bez dobrých lidí dobrá firma neexistuje</h3>
            <div class="slider">
                <div class="slider__arrow slider__arrow-left slider__arrow--disabled" data-follow="centered_y">
                    <img class="slider__arrow-icon" src="/victor/resources/images/icons/arrow.svg" alt="Arrow icon" />
                </div>
                <div class="slider__arrow slider__arrow-right" data-follow="centered_y">
                    <img class="slider__arrow-icon" src="/victor/resources/images/icons/arrow.svg" alt="Arrow icon" />
                </div>
                <div class="slider__inner" id="slider">
                    <div class="slider__item">
                        <img class="slider__item-image" src="/victor/resources/images/persons/person1.jpg" alt="Team photo" />
                        <div class="slider__item-content">
                            <h2 class="slider__item-name">Jan Novák</h2>
                            <h2 class="slider__item-position">FOUNDER & CEO</h2>
                        </div>
                    </div>
                    <div class="slider__item">
                        <img class="slider__item-image" src="/victor/resources/images/persons/person2.jpg" alt="Team photo" />
                        <div class="slider__item-content">
                            <h2 class="slider__item-name">Anna Svobodová</h2>
                            <h2 class="slider__item-position">CTO / MINING OPS</h2>
                        </div>
                    </div>
                    <div class="slider__item">
                        <img class="slider__item-image" src="/victor/resources/images/persons/person3.jpg" alt="Team photo" />
                        <div class="slider__item-content">
                            <h2 class="slider__item-name">Petr Dvořák</h2>
                            <h2 class="slider__item-position">SUPPORT & SERVIS</h2>
                        </div>
                    </div>
                    <div class="slider__item">
                        <img class="slider__item-image" src="/victor/resources/images/persons/person4.jpg" alt="Team photo" />
                        <div class="slider__item-content">
                            <h2 class="slider__item-name">Markéta Horáková</h2>
                            <h2 class="slider__item-position">BUSINESS DEV</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- HEADER -->
    <header class="fixed-content-header">
        <div class="flex flex--center">
            <div class="burger" data-follow>
                <div class="burger__line"></div>
                <div class="burger__line"></div>
                <div class="burger__line"></div>
            </div>
            <div class="fixed-content-header__logo">NEW FACTORY</div>
        </div>
        <button class="fixed-content-header__contact button button--primary" data-follow data-page="5">KONTAKT</button>
    </header>

    <!-- PAGING -->
    <div class="fixed-content-paging">
        <div class="paging__page" data-page="0"></div>
        <div class="paging__page section--hidden" data-page="1"></div>
        <div class="paging__page section--hidden" data-page="2"></div>
        <div class="paging__page section--hidden" data-page="3"></div>
        <div class="paging__page section--hidden" data-page="4"></div>
        <div class="paging__page section--hidden" data-page="5"></div>
    </div>

    <!-- FOOTER -->
    <div class="fixed-content-footer">
        <div class="social-links">
            <a class="social-links__anchor" href="#">
                <img class="social-links__image" src="/victor/resources/images/socials/facebook.svg" alt="Facebook logo" width="20" height="20">
            </a>
            <a class="social-links__anchor" href="#">
                <img class="social-links__image" src="/victor/resources/images/socials/twitter.svg" alt="X / Twitter logo" width="20" height="20">
            </a>
            <a class="social-links__anchor" href="#">
                <img class="social-links__image" src="/victor/resources/images/socials/instagram.svg" alt="Instagram logo" width="20" height="20">
            </a>
        </div>
        <div class="fixed-content-footer__copy">
            <span class="footer-copy__date"></span>
            <span class="footer-copy__name">New Factory · mining@new-factory.cz</span>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="content">

        <!-- Section 0 — HERO / intro letters -->
        <div class="content-section" data-page="0">
            <div class="configuration__letters configuration__letters--hidden">
                <span class="configuration__letters-text">NEW FACTORY</span>
            </div>
            <div class="scroll-letters">
                <span class="scroll-letters__letter" title="S">S</span>
                <span class="scroll-letters__letter" title="C">C</span>
                <span class="scroll-letters__letter" title="R">R</span>
                <span class="scroll-letters__letter" title="O">O</span>
                <span class="scroll-letters__letter" title="L">L</span>
                <span class="scroll-letters__letter" title="L">L</span>
            </div>
        </div>

        <!-- Section 1 — MACHINES (full long-form editorial: rail numbers, ALL-IN sidebar, expandable detail) -->
        <div class="content-section section--hidden content-section--scrollable nf-section-stroje" data-page="1">
            <header class="nf-section-stroje__head">
                <span class="nf-eyebrow">{{ homepage.hero_eyebrow|default('[NABÍDKA / 03]') }}</span>
                <h1 class="nf-display nf-section-stroje__title">{{ homepage.hero_title_top|default('STROJE') }}<br><span class="nf-display--accent">{{ homepage.hero_title_bottom|default('NA TĚŽBU')|replace({' ': '&nbsp;'})|raw }}</span></h1>
                <p class="nf-section-stroje__lead">{{ homepage.hero_lead|default('Tři ASIC mineři. Plně transparentní all-in cena — stroj + doprava + clo + pojištění v jednom čísle. Hosting, monitoring a servis si vybíráte sami.') }}</p>
            </header>

            <ol class="nf-machines">
                {% for product in products|default([]) %}
                    {% set base = product.machine_price_czk + product.accessories_czk %}
                    {% set required = 0 %}
                    {% set optional_total = 0 %}
                    {% for line in product.service_lines %}
                        {% if line.is_optional %}
                            {% set optional_total = optional_total + line.price_czk %}
                        {% else %}
                            {% set required = required + line.price_czk %}
                        {% endif %}
                    {% endfor %}
                    {% set allin = base + required %}
                    {% set efficiency = (product.power_w / (product.hashrate|split(' ')[0]))|round(1) %}

                    <li class="nf-machine" id="machine-{{ product.slug }}" data-product-slug="{{ product.slug }}">
                        <span class="nf-machine__index">{{ '%02d'|format(loop.index) }}</span>
                        <span class="nf-machine__badge nf-machine__badge--{{ product.delivery|lower|replace({' ': '-'}) }}">{{ product.delivery }}</span>

                        <div class="nf-machine__heading">
                            <p class="nf-machine__kicker"><span class="nf-mono">{{ product.manufacturer|upper }}</span> · <span class="nf-mono">{{ product.algorithm }}</span> · <span class="nf-mono">{{ product.currency_type|upper }}</span></p>
                            <h2 class="nf-display nf-machine__name">{{ product.name }}</h2>
                        </div>

                        <div class="nf-machine__hash">
                            <span class="nf-machine__hash-label">HASHRATE</span>
                            <strong class="nf-display nf-machine__hash-value">{{ product.hashrate|split(' ')[0] }}</strong>
                            <span class="nf-machine__hash-unit">{{ product.hashrate|split(' ')[1]|default('TH/s') }}</span>
                        </div>

                        <dl class="nf-machine__stats">
                            <div><dt>Příkon</dt><dd class="nf-mono">{{ product.power_w|number_format(0, ',', ' ') }} W</dd></div>
                            <div><dt>Účinnost</dt><dd class="nf-mono">{{ efficiency }} J/TH</dd></div>
                            <div><dt>Roční výnos<sup title="Odhad podle aktuální obtížnosti sítě a kurzu BTC; výsledná hodnota není garantovaná.">ⓘ</sup></dt><dd class="nf-mono">{{ product.annual_btc }}</dd></div>
                            <div><dt>El. @ 5&nbsp;Kč/kWh</dt><dd class="nf-mono">{{ product.electricity_yearly_czk|number_format(0, ',', ' ') }} Kč / rok</dd></div>
                        </dl>

                        <aside class="nf-machine__price">
                            <p class="nf-machine__price-eyebrow">ALL-IN CENA</p>
                            <p class="nf-display nf-machine__price-value">{{ allin|number_format(0, ',', ' ') }}<small> Kč</small></p>
                            <ul class="nf-machine__price-lines">
                                <li><span>Stroj</span><span class="nf-mono">{{ product.machine_price_czk|number_format(0, ',', ' ') }}</span></li>
                                <li><span>Příslušenství</span><span class="nf-mono">{{ product.accessories_czk|number_format(0, ',', ' ') }}</span></li>
                                <li><span>Doprava + clo + pojištění</span><span class="nf-mono">{{ required|number_format(0, ',', ' ') }}</span></li>
                            </ul>
                            <p class="nf-machine__price-note">+ <span class="nf-mono">{{ product.electricity_yearly_czk|number_format(0, ',', ' ') }} Kč</span> elektřina / rok (zvlášť)</p>
                            <div class="nf-machine__actions">
                                <a class="nf-btn nf-btn--primary" href="{{ path('contact', { product: product.slug }) }}">Nezávazná poptávka →</a>
                                <a class="nf-btn nf-btn--ghost" href="{{ path('product_detail', { slug: product.slug }) }}">Detail stroje</a>
                            </div>
                        </aside>

                        <details class="nf-machine__breakdown">
                            <summary>Co dalšího lze přiobjednat <span class="nf-mono">[{{ product.service_lines|length }} položek]</span></summary>
                            <ul>
                                {% for line in product.service_lines %}
                                    <li class="{{ line.is_optional ? 'is-optional' : 'is-required' }}">
                                        <span>{{ line.is_optional ? '◇' : '◆' }} {{ line.name }}{% if line.is_optional %} <em>volitelné</em>{% endif %}</span>
                                        <strong class="nf-mono">{{ line.price_czk|number_format(0, ',', ' ') }} Kč</strong>
                                    </li>
                                {% endfor %}
                            </ul>
                            <p class="nf-machine__breakdown-note">S volitelnými službami až <span class="nf-mono">{{ (allin + optional_total)|number_format(0, ',', ' ') }} Kč</span>.</p>
                        </details>
                    </li>
                {% endfor %}
            </ol>
        </div>

        <!-- Section 2 — SERVICES (compact 3-up at-a-glance triptych; full detail on /produkty/{slug}) -->
        <div class="content-section section--hidden content-section--scrollable nf-section-stroje" data-page="2">
            <header class="nf-section-stroje__head">
                <span class="nf-eyebrow">[SLUŽBY / 03]</span>
                <h1 class="nf-display nf-section-stroje__title">SLUŽBY<br><span class="nf-display--accent">PRO&nbsp;TĚŽBU</span></h1>
                <p class="nf-section-stroje__lead">Tři ASIC mineři side-by-side. Plně transparentní all-in cena <span class="nf-mono">— stroj + doprava + clo + pojištění v jednom čísle.</span> Detail rozpočtu a volitelné služby na stránce stroje.</p>
            </header>

            <ol class="nf-machines nf-machines--triptych">
                {% for product in products|default([]) %}
                    {% set base = product.machine_price_czk + product.accessories_czk %}
                    {% set required = 0 %}
                    {% for line in product.service_lines %}
                        {% if not line.is_optional %}
                            {% set required = required + line.price_czk %}
                        {% endif %}
                    {% endfor %}
                    {% set allin = base + required %}
                    {% set efficiency = (product.power_w / (product.hashrate|split(' ')[0]))|round(1) %}

                    <li class="nf-machine nf-machine--compact" id="service-machine-{{ product.slug }}" data-product-slug="{{ product.slug }}">
                        <header class="nf-machine__compact-head">
                            <span class="nf-machine__index">{{ '%02d'|format(loop.index) }}</span>
                            <span class="nf-machine__badge nf-machine__badge--{{ product.delivery|lower|replace({' ': '-'}) }}">{{ product.delivery }}</span>
                        </header>

                        <div class="nf-machine__heading">
                            <p class="nf-machine__kicker"><span class="nf-mono">{{ product.manufacturer|upper }}</span> · <span class="nf-mono">{{ product.algorithm }}</span></p>
                            <h2 class="nf-display nf-machine__name">{{ product.name }}</h2>
                        </div>

                        <div class="nf-machine__hash">
                            <span class="nf-machine__hash-label">HASHRATE</span>
                            <strong class="nf-display nf-machine__hash-value">{{ product.hashrate|split(' ')[0] }}</strong>
                            <span class="nf-machine__hash-unit">{{ product.hashrate|split(' ')[1]|default('TH/s') }}</span>
                        </div>

                        <dl class="nf-machine__stats nf-machine__stats--compact">
                            <div><dt>Příkon</dt><dd class="nf-mono">{{ product.power_w|number_format(0, ',', ' ') }} W</dd></div>
                            <div><dt>Účinnost</dt><dd class="nf-mono">{{ efficiency }} J/TH</dd></div>
                        </dl>

                        <aside class="nf-machine__price nf-machine__price--compact">
                            <p class="nf-machine__price-eyebrow">ALL-IN CENA</p>
                            <p class="nf-display nf-machine__price-value">{{ allin|number_format(0, ',', ' ') }}<small> Kč</small></p>
                            <p class="nf-machine__price-note">+ <span class="nf-mono">{{ product.electricity_yearly_czk|number_format(0, ',', ' ') }} Kč</span> el. / rok</p>
                            <div class="nf-machine__actions">
                                <a class="nf-btn nf-btn--primary" href="{{ path('product_detail', { slug: product.slug }) }}">Detail stroje →</a>
                                <a class="nf-btn nf-btn--ghost" href="{{ path('contact', { product: product.slug }) }}">Nezávazná poptávka</a>
                            </div>
                        </aside>
                    </li>
                {% endfor %}
            </ol>

            <footer class="nf-section-stroje__foot">
                <a class="nf-btn nf-btn--ghost" href="{{ path('product_list') }}">Plné srovnání &amp; rozpis služeb →</a>
            </footer>
        </div>

        <!-- Section 3 — PROČ NÁS (transparency + customer questions answered) -->
        <div class="content-section section--hidden content-section--scrollable" data-page="3">
            <h1 class="content-section__title">{{ homepage.benefits_title|default('PROČ PRÁVĚ NEW FACTORY') }}</h1>
            <p class="content-section__text">{{ homepage.benefits_lead|default('Šest věcí, které dělají rozdíl mezi solidním a špatným hosting providerem.') }}</p>
            <div class="benefits-grid">
                {% for benefit in benefits|default([]) %}
                    <article class="benefit">
                        <h3 class="benefit__title">{{ benefit.title }}</h3>
                        <p>{{ benefit.body }}</p>
                    </article>
                {% endfor %}
            </div>
        </div>

        <!-- Section 4 — TEAM -->
        <div class="content-section section--hidden content-section--left-align" data-page="4">
            <div class="content-holder--left-align">
                <h1 class="content-section__title">{{ homepage.team_title|default('NÁŠ TÝM') }}</h1>
                <p class="content-section__text text-indent content-section__text-team">{{ homepage.team_lead|default('Firma stojí na lidech, ne na strojích. Náš tým má za sebou roky praxe v mining, hardware servisu i obchodě. Stroj prodáme i tomu, kdo nikdy nemíchal kryptoměnu — provedeme vás od první kalkulace po první vytěžený Bitcoin.') }}</p>
                <button class="content-section__button button button--secondary" id="button_team">PŘEDSTAVIT TÝM</button>
            </div>
            <div class="content-section__images">
                <div class="content-section__image-holder">
                    <img class="content-section__image" src="/victor/resources/images/persons/person1.jpg" alt="Team photo" />
                </div>
                <div class="content-section__image-holder">
                    <img class="content-section__image" src="/victor/resources/images/persons/person2.jpg" alt="Team photo" />
                </div>
                <div class="content-section__image-holder">
                    <img class="content-section__image" src="/victor/resources/images/persons/person3.jpg" alt="Team photo" />
                </div>
                <div class="content-section__image-holder">
                    <img class="content-section__image" src="/victor/resources/images/persons/person4.jpg" alt="Team photo" />
                </div>
            </div>
        </div>

        <!-- Section 5 — CONTACT -->
        <div class="content-section section--hidden" data-page="5">
            <h1 class="content-section__title">{{ homepage.contact_title|default('KONTAKT') }}</h1>
            <p class="content-section__text">{{ homepage.contact_lead|default('Máme rádi vaše otázky — ozveme se do 24 hodin. Konzultace zdarma.') }}</p>
            <div class="content-section__buttons-holder">
                <a class="content-section__button button button--icon" href="mailto:mining@new-factory.cz">
                    <img class="button__image" src="/victor/resources/images/icons/email.svg" alt="Email icon" />
                    <span class="button__text">EMAIL</span>
                    <span class="button__invisible-email">mining@new-factory.cz</span>
                </a>
                <a class="content-section__button button button--icon" href="{{ path('contact') }}">
                    <img class="button__image" src="/victor/resources/images/icons/phone.svg" alt="Form icon" />
                    <span class="button__text">FORMULÁŘ POPTÁVKY</span>
                </a>
            </div>
        </div>
    </div>
</main>
{% endblock %}
