# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

# Strapi env stubs — tests run with a placeholder token so StrapiContentClient
# short-circuits to null (see ::fetchCached check for token starting with '__').
# This makes repositories fall through to their hardcoded fallback copy, which
# is what tests assert on. No outbound HTTP from the test suite.
NEWFACTORY_STRAPI_URL=http://strapi.invalid
NEWFACTORY_STRAPI_API_TOKEN=__test_stub__
NEWFACTORY_SENTRY_DSN=
NEWFACTORY_LEAD_RECIPIENT=test@example.com
NEWFACTORY_MAIL_HTTP_API_URL=http://mail.invalid
NEWFACTORY_MAIL_RELAY_API_KEY=__test_stub__
